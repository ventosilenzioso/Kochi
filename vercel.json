{
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/v1/device",
      "dest": "/api/index.js"
    },
    {
      "src": "/v1/task",
      "dest": "/api/index.js"
    },
    {
      "src": "/v1/task/complete",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/devices",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/tasks",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/tasks/add",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/stats",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
